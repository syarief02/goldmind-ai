# ============================================================
# GoldMind AI — Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================

# ---- OpenAI API ----
# Your OpenAI API key (required)
OPENAI_API_KEY=sk-your-key-here

# ---- Model Selection ----
# Primary model (must support Structured Outputs)
# Uncomment ONE of the following models:
#
# OPENAI_MODEL=gpt-4o-2024-08-06   # Fast, affordable, great for most users
OPENAI_MODEL=gpt-5-mini             # Better analysis, moderate cost (default)
# OPENAI_MODEL=gpt-5                # Strong accuracy, higher cost
# OPENAI_MODEL=gpt-5.2              # Advanced analysis, premium cost
# OPENAI_MODEL=gpt-5.4              # Best accuracy, highest cost

# Fallback model (used if primary model times out or fails)
FALLBACK_MODEL=gpt-5